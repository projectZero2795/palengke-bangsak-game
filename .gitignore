# Unity generated folders are added in Phase 1.
Library/
Temp/
Obj/
Build/
Builds/
Logs/
UserSettings/

# IDE/editor
.DS_Store
.idea/
.vscode/

# Local environment
.env
.env.*

# Android signing material must never enter Git.
*.jks
*.keystore
*.p12
*.pfx

# Photon local secrets/config generated by Unity packages should stay local.
unity/Assets/Resources/PhotonAppIdLocal.asset
unity/Assets/Resources/PhotonAppIdLocal.asset.meta
unity/Assets/Photon/Fusion/Resources/PhotonAppSettings.asset
unity/Assets/Photon/Fusion/Resources/PhotonAppSettings.asset.meta

# Python helper scripts
__pycache__/
*.pyc
