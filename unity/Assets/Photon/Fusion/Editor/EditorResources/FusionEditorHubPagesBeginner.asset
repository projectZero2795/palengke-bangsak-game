        WidgetMode:
          Value: Text
        AutoComplete:
          Value: None
        Hide:
          Value: None
        Scene: 
        AddSceneToTop: 0
        Icon: {fileID: 0}
        StatusIcon: {fileID: 0}
        StartPlayMode: 0
        Url: 
        Type:
          ScriptableObject: 
          Class: 
        Asset: {fileID: 0}
        Id: a375765f-4f17-47d7-aee8-bf70ee016eee
      - Text: Photon Dashboard (Opens Web Browser)
        Subtext: Register a Photon account and create free AppIds
