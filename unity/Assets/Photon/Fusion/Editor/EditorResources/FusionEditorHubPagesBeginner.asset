      Id: fdd69fd4-9268-44d6-9136-9f67f653477e
      StepElements:
      - Text: Install Fusion Intro Sample
        Subtext: 
        WidgetMode:
          Value: InstallPackage
        AutoComplete:
          Value: None
        Hide:
          Value: None
        Scene: Assets/Photon/FusionDemos/Fusion-Intro-Shared/Scenes/FusionIntroShared.unity
