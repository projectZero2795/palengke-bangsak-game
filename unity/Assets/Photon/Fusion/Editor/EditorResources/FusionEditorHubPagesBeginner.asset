        Id: 6861967a-1e87-4fa7-85ec-ad198c24c6ca
    - Text: Register to a Photon account on our website and create an AppId to run
        online games.
      Subtext: 
      WidgetMode:
        Value: Step
      AutoComplete:
        Value: AppIdCreated
      Hide:
        Value: None
      Scene: 
      AddSceneToTop: 0
      Icon: {fileID: 0}
      StatusIcon: {fileID: 0}
      StartPlayMode: 0
      Url: 
      Type:
        ScriptableObject: 
        Class: 
      Asset: {fileID: 0}
      Id: 97006100-31d0-4249-be0e-1721da7d730c
      StepElements:
      - Text: "<b>A Fusion 2 AppId is required to connect to the Fusion public cloud:</b>\r\n 
          - Open the Photon Dashboard link log in or register an account.\r\n  -
          Select an existing Fusion 2 AppId or create a new one.\r\n  - Copy the
          App Id and paste into the field below."
